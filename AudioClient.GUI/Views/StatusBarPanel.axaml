<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AudioClient.GUI.ViewModels"
             xmlns:v="clr-namespace:AudioClient.GUI.Views"
             xmlns:models="clr-namespace:AudioClient.Core.Models;assembly=AudioClient.Core"
             x:Class="AudioClient.GUI.Views.StatusBarPanel"
             x:DataType="vm:StatusBarViewModel"
             Background="{StaticResource BrushBgDark}"
             Height="52">

    <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="12,0">

        <Button Grid.Column="3" Content="Sign In"
                Command="{Binding ShowLoginCommand}"
                Background="Transparent" Foreground="{StaticResource BrushTextMuted}"
                FontSize="12" Padding="8,4" VerticalAlignment="Center"
                ToolTip.Tip="Sign in to Resonite" />

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Button x:Name="MuteBtn"
                    Command="{Binding ToggleMuteCommand}"
                    Background="{Binding IsMicActive, Converter={x:Static v:BoolToBrushConverter.Instance}, ConverterParameter='GreenDim:Transparent'}"
                    Foreground="{Binding IsMuted, Converter={x:Static v:BoolToBrushConverter.Instance}, ConverterParameter='Red:TextPrimary'}"
                    Padding="6" VerticalAlignment="Center"
                    ToolTip.Tip="Toggle Mute">
                <Path Width="18" Height="18"
                      Data="{Binding IsMuted, Converter={x:Static v:BoolToGeometryConverter.Instance}, ConverterParameter='IconMicOff:IconMic'}"
                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Stretch="Uniform" />
            </Button>

            <Button x:Name="InputDeviceBtn"
                    Command="{Binding ToggleInputDevicePopupCommand}"
                    Background="Transparent" Foreground="{StaticResource BrushTextMuted}"
                    Padding="6" VerticalAlignment="Center"
                    ToolTip.Tip="Input device">
                <Path Width="12" Height="12" Data="{StaticResource IconChevronDown}"
                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Stretch="Uniform" />
            </Button>
            <Popup IsOpen="{Binding IsInputDevicePopupOpen, Mode=TwoWay}"
                   PlacementTarget="{Binding ElementName=InputDeviceBtn}"
                   Placement="Top" IsLightDismissEnabled="True">
                <Border Background="{StaticResource BrushBgLight}" CornerRadius="6" Padding="6"
                        BoxShadow="0 4 16 0 #88000000">
                    <ScrollViewer MaxHeight="260">
                        <ItemsControl ItemsSource="{Binding InputDevices}" MinWidth="220">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DeviceInfo">
                                    <Button Command="{Binding $parent[ItemsControl].((vm:StatusBarViewModel)DataContext).SetInputDeviceCommand}"
                                            CommandParameter="{Binding Index}"
                                            Background="Transparent"
                                            Foreground="{Binding IsActive, Converter={x:Static v:BoolToBrushConverter.Instance}, ConverterParameter='TextPrimary:TextMuted'}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="8,5">
                                        <Grid ColumnDefinitions="16,*">
                                            <TextBlock Grid.Column="0" Text="✓" IsVisible="{Binding IsActive}"
                                                       FontWeight="Bold" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Popup>

            <Border Background="{StaticResource BrushBgMid}" CornerRadius="4" Padding="6" Margin="4,0,2,0"
                    ToolTip.Tip="{Binding CurrentVoiceMode}">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10"
                             Fill="{Binding CurrentVoiceMode, Converter={x:Static v:VoiceModeBrushConverter.Instance}}"
                             VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <Button Command="{Binding ToggleVoiceModePopupCommand}"
                    Background="Transparent" Foreground="{StaticResource BrushTextMuted}"
                    Padding="6" VerticalAlignment="Center"
                    ToolTip.Tip="Voice mode">
                <Path Width="12" Height="12" Data="{StaticResource IconChevronDown}"
                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Stretch="Uniform" />
            </Button>
            <Popup IsOpen="{Binding IsVoiceModePopupOpen, Mode=TwoWay}"
                   PlacementTarget="{Binding ElementName=MuteBtn}"
                   Placement="Top" IsLightDismissEnabled="True">
                <Border Background="{StaticResource BrushBgLight}" CornerRadius="6" Padding="6"
                        BoxShadow="0 4 16 0 #88000000">
                    <StackPanel Spacing="2" Width="160">
                        <Button Command="{Binding SetVoiceModeCommand}" CommandParameter="Whisper"
                                Background="Transparent" Foreground="{StaticResource BrushTextPrimary}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="8,5">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource BrushPurple}" VerticalAlignment="Center" />
                                <TextBlock Text="Whisper" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SetVoiceModeCommand}" CommandParameter="Normal"
                                Background="Transparent" Foreground="{StaticResource BrushTextPrimary}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="8,5">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource BrushGreen}" VerticalAlignment="Center" />
                                <TextBlock Text="Normal" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SetVoiceModeCommand}" CommandParameter="Shout"
                                Background="Transparent" Foreground="{StaticResource BrushTextPrimary}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="8,5">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource BrushYellow}" VerticalAlignment="Center" />
                                <TextBlock Text="Shout" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SetVoiceModeCommand}" CommandParameter="Broadcast"
                                Background="Transparent" Foreground="{StaticResource BrushTextPrimary}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="8,5">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource BrushCyan}" VerticalAlignment="Center" />
                                <TextBlock Text="Broadcast" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4" Margin="8,0">
            <Button x:Name="SpeakerIcon"
                    Command="{Binding ToggleSpeakerMuteCommand}"
                    Background="Transparent" Foreground="{StaticResource BrushTextMuted}"
                    Padding="6" VerticalAlignment="Center"
                    ToolTip.Tip="Toggle Speaker Mute">
                <Path Width="18" Height="18"
                      Data="{Binding IsSpeakerMuted, Converter={x:Static v:BoolToGeometryConverter.Instance}, ConverterParameter='IconSpeakerOff:IconSpeaker'}"
                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Stretch="Uniform" />
            </Button>

            <Button x:Name="OutputDeviceBtn"
                    Command="{Binding ToggleOutputDevicePopupCommand}"
                    Background="Transparent" Foreground="{StaticResource BrushTextMuted}"
                    Padding="6" VerticalAlignment="Center"
                    ToolTip.Tip="Output device">
                <Path Width="12" Height="12" Data="{StaticResource IconChevronDown}"
                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Stretch="Uniform" />
            </Button>
            <Popup IsOpen="{Binding IsOutputDevicePopupOpen, Mode=TwoWay}"
                   PlacementTarget="{Binding ElementName=OutputDeviceBtn}"
                   Placement="Top" IsLightDismissEnabled="True">
                <Border Background="{StaticResource BrushBgLight}" CornerRadius="6" Padding="6"
                        BoxShadow="0 4 16 0 #88000000">
                    <ScrollViewer MaxHeight="260">
                        <ItemsControl ItemsSource="{Binding OutputDevices}" MinWidth="220">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DeviceInfo">
                                    <Button Command="{Binding $parent[ItemsControl].((vm:StatusBarViewModel)DataContext).SetOutputDeviceCommand}"
                                            CommandParameter="{Binding Index}"
                                            Background="Transparent"
                                            Foreground="{Binding IsActive, Converter={x:Static v:BoolToBrushConverter.Instance}, ConverterParameter='TextPrimary:TextMuted'}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="8,5">
                                        <Grid ColumnDefinitions="16,*">
                                            <TextBlock Grid.Column="0" Text="✓" IsVisible="{Binding IsActive}"
                                                       FontWeight="Bold" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Popup>

            <Slider Value="{Binding MasterVolume}" Minimum="0" Maximum="1"
                    Width="90" VerticalAlignment="Center" />
            <TextBlock Text="{Binding MasterVolume, StringFormat={}{0:P0}}"
                       Foreground="{StaticResource BrushTextMuted}" FontSize="12" VerticalAlignment="Center" />

            <Button Command="{Binding ToggleVolumePopupCommand}"
                    Background="Transparent" Foreground="{StaticResource BrushTextMuted}"
                    Padding="6" VerticalAlignment="Center"
                    ToolTip.Tip="Volume details">
                <Path Width="12" Height="12" Data="{StaticResource IconChevronDown}"
                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Stretch="Uniform" />
            </Button>
            <Popup IsOpen="{Binding IsVolumePopupOpen, Mode=TwoWay}"
                   PlacementTarget="{Binding ElementName=SpeakerIcon}"
                   Placement="Top" IsLightDismissEnabled="True">
                <Border Background="{StaticResource BrushBgLight}" CornerRadius="6" Padding="12"
                        BoxShadow="0 4 16 0 #88000000">
                    <StackPanel Spacing="6" Width="220">
                        <TextBlock Text="Sound Effect" Foreground="{StaticResource BrushTextPrimary}" FontSize="12" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Slider Grid.Column="0" Value="{Binding SoundEffectVolume}" Minimum="0" Maximum="1" />
                            <TextBlock Grid.Column="1" Text="{Binding SoundEffectVolume, StringFormat={}{0:P0}}"
                                       Foreground="{StaticResource BrushTextMuted}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0" Width="36" />
                        </Grid>
                        <TextBlock Text="Multimedia" Foreground="{StaticResource BrushTextPrimary}" FontSize="12" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Slider Grid.Column="0" Value="{Binding MultimediaVolume}" Minimum="0" Maximum="1" />
                            <TextBlock Grid.Column="1" Text="{Binding MultimediaVolume, StringFormat={}{0:P0}}"
                                       Foreground="{StaticResource BrushTextMuted}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0" Width="36" />
                        </Grid>
                        <TextBlock Text="Voice" Foreground="{StaticResource BrushTextPrimary}" FontSize="12" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Slider Grid.Column="0" Value="{Binding VoiceVolume}" Minimum="0" Maximum="1" />
                            <TextBlock Grid.Column="1" Text="{Binding VoiceVolume, StringFormat={}{0:P0}}"
                                       Foreground="{StaticResource BrushTextMuted}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0" Width="36" />
                        </Grid>
                        <TextBlock Text="UI" Foreground="{StaticResource BrushTextPrimary}" FontSize="12" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Slider Grid.Column="0" Value="{Binding UIVolume}" Minimum="0" Maximum="1" />
                            <TextBlock Grid.Column="1" Text="{Binding UIVolume, StringFormat={}{0:P0}}"
                                       Foreground="{StaticResource BrushTextMuted}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0" Width="36" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Popup>
        </StackPanel>

    </Grid>
</UserControl>
