<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AudioClient.GUI.ViewModels"
        xmlns:v="clr-namespace:AudioClient.GUI.Views"
        x:Class="AudioClient.GUI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="AudioClient"
        Icon="/AudioClientIcon.ico"
        Width="1160" Height="900"
        MinWidth="800" MinHeight="400"
        Background="{StaticResource BrushBgDark}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        SystemDecorations="Full">

    <Grid>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{StaticResource BrushBgDark}" Height="32"
                IsHitTestVisible="True"
                PointerPressed="TitleBar_PointerPressed">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="AudioClient" Foreground="{StaticResource BrushTextPrimary}"
                           VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold" IsHitTestVisible="False" />
                <!-- Close button -->
                <Button Grid.Column="1" Content="✕" Click="CloseButton_Click"
                        Background="Transparent" Foreground="{StaticResource BrushTextMuted}"
                        Width="32" Height="32" Padding="0" FontSize="14"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
            </Grid>
        </Border>

        <!-- Main area: 4 columns — Chat is now below SessionDetail in column 2 -->
        <!-- Update banner -->
        <Border Grid.Row="1" IsVisible="{Binding IsUpdateAvailable}"
                Background="{StaticResource BrushBgMid}"
                BorderBrush="{StaticResource BrushYellow}"
                BorderThickness="0,1,0,1"
                Padding="12,8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <TextBlock Grid.Column="0" Text="{Binding UpdateStatusMessage}"
                           Foreground="{StaticResource BrushTextPrimary}"
                           VerticalAlignment="Center" FontSize="12"
                           TextWrapping="Wrap" />
                <Button Grid.Column="1" Content="{Binding UpdateButtonText}"
                        Command="{Binding InstallUpdateCommand}"
                        IsEnabled="{Binding !IsUpdating}"
                        Background="{StaticResource BrushYellow}"
                        Foreground="{StaticResource BrushBgDark}"
                        Padding="12,4" FontSize="12" FontWeight="SemiBold"
                        MinWidth="88" HorizontalContentAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="200,200,*,200">

            <!-- Far Left: tabbed Browse / Contacts -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*">
                <!-- Tab header -->
                <Grid Grid.Row="0" ColumnDefinitions="*,*" Background="{StaticResource BrushBgDark}">
                    <Button Grid.Column="0" Content="Browse"
                            Command="{Binding SelectLeftTabCommand}" CommandParameter="Browse"
                            Background="Transparent"
                            Foreground="{Binding IsBrowseTabSelected, Converter={x:Static v:BoolToBrushConverter.Instance}, ConverterParameter='TextPrimary:TextMuted'}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Padding="0,8" FontSize="12" CornerRadius="0" />
                    <Button Grid.Column="1" Content="Contacts"
                            Command="{Binding SelectLeftTabCommand}" CommandParameter="Contacts"
                            Background="Transparent"
                            Foreground="{Binding IsContactsTabSelected, Converter={x:Static v:BoolToBrushConverter.Instance}, ConverterParameter='TextPrimary:TextMuted'}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Padding="0,8" FontSize="12" CornerRadius="0" />
                </Grid>
                <!-- Tab content -->
                <Border Grid.Row="1" IsVisible="{Binding IsBrowseTabSelected}">
                    <v:BrowseSessionsPanel DataContext="{Binding BrowseSessions}" />
                </Border>
                <Border Grid.Row="1" IsVisible="{Binding IsContactsTabSelected}">
                    <v:ContactListPanel DataContext="{Binding ContactList}" />
                </Border>
            </Grid>

            <!-- Left: Session List -->
            <v:SessionListPanel Grid.Column="1" DataContext="{Binding SessionList}" />

            <!-- Center: Session Detail (top bar) + Chat (below) -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*">

                <!-- Row 0: compact session detail bar (only when engine ready) -->
                <Border Grid.Row="0" IsVisible="{Binding IsEngineReady}">
                    <v:SessionDetailPanel DataContext="{Binding SessionDetail}" />
                </Border>

                <!-- Row 1: video list + chat area -->
                <Grid Grid.Row="1" x:Name="CenterContentGrid" RowDefinitions="Auto,*">
                    <v:VideoListPanel x:Name="VideoListPanelCtrl" Grid.Row="0" DataContext="{Binding Videos}" />

                    <!-- Loading overlay -->
                    <StackPanel IsVisible="{Binding !IsEngineReady}"
                                Grid.RowSpan="2"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <TextBlock Text="Initializing..." Foreground="{StaticResource BrushTextPrimary}"
                                   FontSize="18" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrushTextMuted}"
                                   FontSize="12" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="300" />
                    </StackPanel>

                    <!-- Chat Panel — always visible; availability state handled inside the panel -->
                    <v:ChatPanel Grid.Row="1" DataContext="{Binding Chat}" />
                </Grid>

                <!-- Overlays spanning both rows -->
                <v:SessionPreviewPanel Grid.RowSpan="2" IsVisible="False" DataContext="{Binding SessionPreview}" />
                <v:LoginPanel Grid.RowSpan="2" IsVisible="False" DataContext="{Binding Login}" />
                <v:UserInfoPanel Grid.RowSpan="2" IsVisible="False" DataContext="{Binding UserInfoPopup}" />
                <v:SessionSettingsPanel Grid.RowSpan="2" IsVisible="False" DataContext="{Binding SessionDetail}" />
                <v:NewSessionPanel Grid.RowSpan="2" IsVisible="False" DataContext="{Binding NewSession}" />
                <v:SettingsPanel Grid.RowSpan="2" IsVisible="False" DataContext="{Binding Settings}" />
            </Grid>

            <!-- Column 3: Member List -->
            <v:MemberListPanel Grid.Column="3" DataContext="{Binding MemberList}" />

        </Grid>

        <!-- Bottom: Status Bar -->
        <v:StatusBarPanel Grid.Row="3" DataContext="{Binding StatusBar}" />

    </Grid>

    <!-- Video full-screen overlay -->
    <Grid IsVisible="{Binding Videos.HasExpandedVideo}" Background="#E6000000">
        <Grid RowDefinitions="44,*">
            <!-- Top bar: title + close -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="16,0,8,0" VerticalAlignment="Center">
                <TextBlock Grid.Column="0"
                           Text="{Binding Videos.ExpandedVideo.Title}"
                           Foreground="{StaticResource BrushTextPrimary}"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1"
                        Command="{Binding Videos.CollapseExpandedVideoCommand}"
                        Background="{StaticResource BrushBgLight}"
                        Foreground="{StaticResource BrushTextPrimary}"
                        Width="36" Height="36" Padding="8" CornerRadius="4"
                        ToolTip.Tip="閉じる">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                  Data="M18 6L6 18" />
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                  Data="M6 6l12 12" />
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>
            <!-- Full-screen video (IsFullScreenVideo bypasses airspace/overlay hide logic) -->
            <Grid Grid.Row="1" DataContext="{Binding Videos.ExpandedVideo}" x:DataType="vm:VideoPlayerItemViewModel"
                  RowDefinitions="*,Auto">
                <v:VlcVideoView Grid.Row="0"
                                IsFullScreenVideo="True"
                                Source="{Binding PlaybackUrl}"
                                IsPlaybackActive="{Binding IsPlaying}"
                                Position="{Binding Position}"
                                Volume="{Binding Volume}"
                                CanSeek="{Binding CanSeek}" />

                <Border Grid.Row="1"
                        Background="#F0101520"
                        BorderBrush="{StaticResource BrushBgLight}"
                        BorderThickness="0,1,0,0"
                        Padding="16,10">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                        <Grid Grid.Row="0"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <Slider Grid.Column="0"
                                    Minimum="0"
                                    Maximum="{Binding SeekMaximum}"
                                    Value="{Binding Position, Mode=TwoWay}"
                                    IsEnabled="{Binding CanSeek}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding PositionText}"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       FontSize="12"
                                       MinWidth="96"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <Grid Grid.Row="1"
                              ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto"
                              ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Content="Play"
                                    Command="{Binding PlayCommand}"
                                    Background="{StaticResource BrushAccent}"
                                    Foreground="White"
                                    Padding="12,6"
                                    FontSize="13"
                                    CornerRadius="4" />
                            <Button Grid.Column="1"
                                    Content="Pause"
                                    Command="{Binding PauseCommand}"
                                    Background="{StaticResource BrushBgLight}"
                                    Foreground="{StaticResource BrushTextPrimary}"
                                    Padding="12,6"
                                    FontSize="13"
                                    CornerRadius="4" />
                            <Button Grid.Column="2"
                                    Content="Stop"
                                    Command="{Binding StopCommand}"
                                    Background="{StaticResource BrushBgLight}"
                                    Foreground="{StaticResource BrushTextPrimary}"
                                    Padding="12,6"
                                    FontSize="13"
                                    CornerRadius="4" />
                            <Button Grid.Column="3"
                                    Content="|&lt;"
                                    Command="{Binding SeekToStartCommand}"
                                    IsEnabled="{Binding CanSeek}"
                                    Background="{StaticResource BrushBgLight}"
                                    Foreground="{StaticResource BrushTextPrimary}"
                                    Padding="10,6"
                                    FontSize="13"
                                    CornerRadius="4"
                                    ToolTip.Tip="Seek to start" />
                            <CheckBox Grid.Column="4"
                                      Content="Loop"
                                      IsChecked="{Binding IsLooping, Mode=TwoWay}"
                                      IsEnabled="{Binding CanSeek}"
                                      Foreground="{StaticResource BrushTextMuted}"
                                      FontSize="13"
                                      VerticalAlignment="Center" />
                            <Slider Grid.Column="5"
                                    Minimum="0"
                                    Maximum="150"
                                    Value="{Binding Volume, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    MinWidth="120"
                                    ToolTip.Tip="Volume" />
                            <TextBlock Grid.Column="6"
                                       Text="{Binding Volume, StringFormat={}{0:0}%}"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       FontSize="12"
                                       Width="44"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>

    <!-- Shutdown overlay -->
    <Grid IsVisible="{Binding IsShuttingDown}" Background="#CC101520">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
            <TextBlock Text="終了処理中..." Foreground="{StaticResource BrushTextPrimary}"
                       FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Text="データを保存しています。しばらくお待ちください。"
                       Foreground="{StaticResource BrushTextMuted}"
                       FontSize="13" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>

    <v:ImageOverlayView DataContext="{Binding ImageViewer}" />

    </Grid>
</Window>
