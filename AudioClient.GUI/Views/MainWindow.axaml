<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AudioClient.GUI.ViewModels"
        xmlns:v="clr-namespace:AudioClient.GUI.Views"
        x:Class="AudioClient.GUI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="AudioClient"
        Icon="/AudioClientIcon.ico"
        Width="1160" Height="600"
        MinWidth="800" MinHeight="400"
        Background="{StaticResource BrushBgDark}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        SystemDecorations="Full">

    <Grid>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{StaticResource BrushBgDark}" Height="32"
                IsHitTestVisible="True"
                PointerPressed="TitleBar_PointerPressed">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="AudioClient" Foreground="{StaticResource BrushTextPrimary}"
                           VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold" IsHitTestVisible="False" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0"
                            IsHitTestVisible="False">
                    <TextBlock Text="{Binding CurrentUsername}" Foreground="{StaticResource BrushTextMuted}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding IsLoggedIn, Converter={x:Static v:BoolToBrushConverter.Instance},
                                   ConverterParameter='Green:TextMuted'}" />
                </StackPanel>
                <!-- Close button -->
                <Button Grid.Column="2" Content="✕" Click="CloseButton_Click"
                        Background="Transparent" Foreground="{StaticResource BrushTextMuted}"
                        Width="32" Height="32" Padding="0" FontSize="14"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
            </Grid>
        </Border>

        <!-- Main area: 5 columns — the Chat column (Auto) collapses when not in AudioClientWorld -->
        <Grid Grid.Row="1" ColumnDefinitions="200,200,*,Auto,200">

            <!-- Far Left: tabbed Browse / Contacts -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*">
                <!-- Tab header -->
                <Grid Grid.Row="0" ColumnDefinitions="*,*" Background="{StaticResource BrushBgDark}">
                    <Button Grid.Column="0" Content="Browse"
                            Command="{Binding SelectLeftTabCommand}" CommandParameter="Browse"
                            Background="Transparent"
                            Foreground="{Binding IsBrowseTabSelected, Converter={x:Static v:BoolToBrushConverter.Instance}, ConverterParameter='TextPrimary:TextMuted'}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Padding="0,8" FontSize="12" CornerRadius="0" />
                    <Button Grid.Column="1" Content="Contacts"
                            Command="{Binding SelectLeftTabCommand}" CommandParameter="Contacts"
                            Background="Transparent"
                            Foreground="{Binding IsContactsTabSelected, Converter={x:Static v:BoolToBrushConverter.Instance}, ConverterParameter='TextPrimary:TextMuted'}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Padding="0,8" FontSize="12" CornerRadius="0" />
                </Grid>
                <!-- Tab content -->
                <Border Grid.Row="1" IsVisible="{Binding IsBrowseTabSelected}">
                    <v:BrowseSessionsPanel DataContext="{Binding BrowseSessions}" />
                </Border>
                <Border Grid.Row="1" IsVisible="{Binding IsContactsTabSelected}">
                    <v:ContactListPanel DataContext="{Binding ContactList}" />
                </Border>
            </Grid>

            <!-- Left: Session List -->
            <v:SessionListPanel Grid.Column="1" DataContext="{Binding SessionList}" />

            <!-- Center: Session Detail / Loading -->
            <Grid Grid.Column="2">
                <!-- Loading overlay -->
                <StackPanel IsVisible="{Binding !IsEngineReady}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <TextBlock Text="Initializing..." Foreground="{StaticResource BrushTextPrimary}"
                               FontSize="18" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrushTextMuted}"
                               FontSize="12" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="300" />
                </StackPanel>

                <!-- Session detail -->
                <v:SessionDetailPanel IsVisible="{Binding IsEngineReady}"
                                      DataContext="{Binding SessionDetail}" />

                <!-- Session preview overlay (IsVisible managed by SessionPreviewPanel.axaml.cs) -->
                <v:SessionPreviewPanel IsVisible="False" DataContext="{Binding SessionPreview}" />

                <!-- Login overlay (IsVisible managed by LoginPanel.axaml.cs via DataContext) -->
                <v:LoginPanel IsVisible="False" DataContext="{Binding Login}" />

                <!-- User info overlay (IsVisible managed by UserInfoPanel.axaml.cs via DataContext) -->
                <v:UserInfoPanel IsVisible="False" DataContext="{Binding UserInfoPopup}" />
            </Grid>

            <!-- Column 3: Chat Panel — visible only in AudioClientWorld (Auto column collapses when hidden) -->
            <Border Grid.Column="3" IsVisible="{Binding IsAudioClientWorld}">
                <v:ChatPanel Width="280" DataContext="{Binding Chat}" />
            </Border>

            <!-- Column 4: Member List -->
            <v:MemberListPanel Grid.Column="4" DataContext="{Binding MemberList}" />

        </Grid>

        <!-- Bottom: Status Bar -->
        <v:StatusBarPanel Grid.Row="2" DataContext="{Binding StatusBar}" />

    </Grid>

    <!-- Shutdown overlay -->
    <Grid IsVisible="{Binding IsShuttingDown}" Background="#CC101520">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
            <TextBlock Text="終了処理中..." Foreground="{StaticResource BrushTextPrimary}"
                       FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Text="データを保存しています。しばらくお待ちください。"
                       Foreground="{StaticResource BrushTextMuted}"
                       FontSize="13" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>

    </Grid>
</Window>
