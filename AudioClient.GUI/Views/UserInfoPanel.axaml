<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AudioClient.GUI.ViewModels"
             xmlns:h="clr-namespace:AudioClient.GUI.Helpers"
             x:Class="AudioClient.GUI.Views.UserInfoPanel"
             x:DataType="vm:UserInfoViewModel"
             Background="#CC000000">

    <Border Background="{StaticResource BrushBgLight}" CornerRadius="8" Padding="24"
            MaxWidth="300" MaxHeight="240" MinWidth="400"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            BoxShadow="0 8 32 0 #88000000">

        <StackPanel Spacing="12">
            <Grid>
                <TextBlock Text="User Info" Foreground="{StaticResource BrushTextPrimary}"
                           FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                <Button Content="X" Command="{Binding CloseCommand}"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="Transparent" Foreground="{StaticResource BrushTextMuted}"
                        Padding="4" FontSize="14" />
            </Grid>

            <StackPanel Spacing="2">
                <TextBlock Text="Username" Foreground="{StaticResource BrushTextMuted}" FontSize="11" />
                <TextBlock h:ResoniteRichText.Text="{Binding UserName}" Foreground="{StaticResource BrushTextPrimary}"
                           FontSize="15" FontWeight="SemiBold" />
            </StackPanel>

            <StackPanel Spacing="2">
                <TextBlock Text="User ID" Foreground="{StaticResource BrushTextMuted}" FontSize="11" />
                <TextBlock Text="{Binding UserId}" Foreground="{StaticResource BrushTextPrimary}"
                           FontSize="12" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <StackPanel IsVisible="{Binding IsContact}" Orientation="Horizontal" Spacing="6">
                <Path Width="14" Height="14" Data="{StaticResource IconContact}"
                      Fill="{StaticResource BrushGreen}" Stretch="Uniform"
                      VerticalAlignment="Center" />
                <TextBlock Text="In your contacts"
                           Foreground="{StaticResource BrushGreen}" FontSize="12" VerticalAlignment="Center" />
            </StackPanel>

            <Button IsVisible="{Binding !IsContact}"
                    Content="Add to Contacts" Command="{Binding AddContactCommand}"
                    Background="{StaticResource BrushAccent}" Foreground="White"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Padding="0,8" CornerRadius="4"
                    IsEnabled="{Binding !IsAdding}" />
        </StackPanel>
    </Border>
</UserControl>
