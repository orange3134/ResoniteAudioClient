<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AudioClient.GUI.ViewModels"
             xmlns:h="clr-namespace:AudioClient.GUI.Helpers"
             x:Class="AudioClient.GUI.Views.ContactListPanel"
             x:DataType="vm:ContactListViewModel"
             Background="{StaticResource BrushBgMid}">

    <Grid RowDefinitions="*,Auto">

        <!-- Contact list -->
        <ScrollViewer Grid.Row="0">
            <ItemsControl ItemsSource="{Binding Contacts}" Margin="8,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ContactItemViewModel">
                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" Padding="6,5" CornerRadius="4" Margin="0,1"
                                Command="{Binding $parent[ItemsControl].((vm:ContactListViewModel)DataContext).PreviewCommand}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding HasSession}">
                            <Grid ColumnDefinitions="Auto,*,Auto" MinHeight="36">
                                <!-- User icon + status dot overlay -->
                                <Grid Grid.Column="0" Width="26" Height="26" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <!-- Placeholder -->
                                    <Border CornerRadius="13" Background="{StaticResource BrushBgDark}">
                                        <TextBlock Text="{Binding IconLetter}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="11" Foreground="{StaticResource BrushTextMuted}" />
                                    </Border>
                                    <!-- Loaded image -->
                                    <Border CornerRadius="13" ClipToBounds="True"
                                            IsVisible="{Binding IconBitmap, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <Image Source="{Binding IconBitmap}" Stretch="UniformToFill" />
                                    </Border>
                                    <!-- Status dot: bottom-right overlay -->
                                    <Border Width="9" Height="9" CornerRadius="4.5"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Margin="0,0,-1,-1"
                                            Background="{Binding StatusBrush}"
                                            BorderBrush="{StaticResource BrushBgMid}" BorderThickness="1.5" />
                                </Grid>

                                <!-- Name + session info -->
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock h:ResoniteRichText.Text="{Binding Username}"
                                               Foreground="{StaticResource BrushTextPrimary}"
                                               FontSize="13" TextTrimming="CharacterEllipsis" />
                                    <TextBlock h:ResoniteRichText.Text="{Binding SessionName}"
                                               Foreground="{StaticResource BrushTextMuted}"
                                               FontSize="11" TextTrimming="CharacterEllipsis"
                                               IsVisible="{Binding HasSession}" />
                                </StackPanel>

                                <!-- Join hint arrow (only when in session) -->
                                <TextBlock Grid.Column="2" Text="›" FontSize="16"
                                           Foreground="{StaticResource BrushTextMuted}"
                                           VerticalAlignment="Center" Margin="4,0,0,0"
                                           IsVisible="{Binding HasSession}" />
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <TextBlock Grid.Row="1" Text="No online contacts"
                   IsVisible="{Binding !ContactCount}"
                   Foreground="{StaticResource BrushTextMuted}" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,12" />

    </Grid>
</UserControl>
