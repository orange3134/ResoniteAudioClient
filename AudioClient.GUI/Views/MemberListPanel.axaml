<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AudioClient.GUI.ViewModels"
             xmlns:v="clr-namespace:AudioClient.GUI.Views"
             x:Class="AudioClient.GUI.Views.MemberListPanel"
             x:DataType="vm:MemberListViewModel"
             Background="{StaticResource BrushBgMid}">

    <UserControl.Styles>
        <!-- Buttons hidden by default but always take layout space to prevent layout shift -->
        <Style Selector="Grid.MemberRow StackPanel.HoverActions">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>
        <Style Selector="Grid.MemberRow:pointerover StackPanel.HoverActions">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
        </Style>
        <!-- Ensure hover button background is fully opaque -->
        <Style Selector="StackPanel.HoverActions Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrushBgHover}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource BrushBgDark}" BorderThickness="0,0,0,1" Padding="12,10">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="MEMBERS" Foreground="{StaticResource BrushTextMuted}"
                           FontSize="11" FontWeight="SemiBold" LetterSpacing="1" />
                <TextBlock Text="{Binding MemberCount}" Foreground="{StaticResource BrushTextMuted}"
                           FontSize="11" />
            </StackPanel>
        </Border>

        <!-- Member List -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Members}" Margin="8,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:MemberItemViewModel">
                        <!--
                            Background="Transparent" is required so the entire row (including
                            empty space) is hit-testable. Without it the pointer-over state is
                            only active when the mouse is directly over a child element.
                        -->
                        <Grid Classes="MemberRow" Background="Transparent"
                              Margin="0,2" MinHeight="30" ColumnDefinitions="Auto,Auto,*">

                            <!-- User icon + status dot overlay -->
                            <Grid Grid.Column="0" Width="22" Height="22" Margin="0,0,6,0" VerticalAlignment="Center">
                                <!-- Placeholder -->
                                <Border CornerRadius="11" Background="{StaticResource BrushBgDark}">
                                    <TextBlock Text="{Binding IconLetter}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="9" Foreground="{StaticResource BrushTextMuted}" />
                                </Border>
                                <!-- Loaded image -->
                                <Border CornerRadius="11" ClipToBounds="True"
                                        IsVisible="{Binding IconBitmap, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <Image Source="{Binding IconBitmap}" Stretch="UniformToFill" />
                                </Border>
                                <!-- Status dot: bottom-right overlay -->
                                <Border Width="8" Height="8" CornerRadius="4"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Margin="0,0,-1,-1"
                                        Background="{Binding IsPresent, Converter={x:Static v:BoolToBrushConverter.Instance}, ConverterParameter='Green:TextMuted'}"
                                        BorderBrush="{StaticResource BrushBgMid}" BorderThickness="1.5" />
                            </Grid>

                            <!-- Contact icon -->
                            <TextBlock Grid.Column="1" Text="👥" FontSize="10" VerticalAlignment="Center"
                                       IsVisible="{Binding IsContact}" Margin="0,0,4,0"
                                       ToolTip.Tip="In your contacts" />

                            <!-- Username + hover buttons (same cell, buttons overlay on right) -->
                            <Grid Grid.Column="2">
                                <TextBlock Text="{Binding Label}"
                                           Foreground="{StaticResource BrushTextPrimary}"
                                           FontSize="13" VerticalAlignment="Center" />
                                <StackPanel Classes="HoverActions"
                                            Orientation="Horizontal" Spacing="2"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="MoveTo"
                                            Command="{Binding $parent[ItemsControl].((vm:MemberListViewModel)DataContext).MoveToCommand}"
                                            CommandParameter="{Binding}"
                                            Background="{StaticResource BrushBgDark}"
                                            Foreground="{StaticResource BrushTextPrimary}"
                                            FontSize="10" Padding="4,2" CornerRadius="3" />
                                    <Button Content="Info"
                                            Command="{Binding $parent[ItemsControl].((vm:MemberListViewModel)DataContext).ShowInfoCommand}"
                                            CommandParameter="{Binding}"
                                            Background="{StaticResource BrushBgDark}"
                                            Foreground="{StaticResource BrushTextPrimary}"
                                            FontSize="10" Padding="4,2" CornerRadius="3" />
                                </StackPanel>
                            </Grid>

                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
