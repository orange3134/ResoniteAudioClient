<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AudioClient.GUI.ViewModels"
             xmlns:h="clr-namespace:AudioClient.GUI.Helpers"
             x:Class="AudioClient.GUI.Views.SessionDetailPanel"
             x:DataType="vm:SessionDetailViewModel"
             Background="{StaticResource BrushBgMid}">

    <Border BorderBrush="{StaticResource BrushBgDark}" BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,Auto" Height="44" Margin="12,0">

            <!-- Left: placeholder or session info -->
            <TextBlock Grid.Column="0"
                       Text="No session focused"
                       Foreground="{StaticResource BrushTextMuted}"
                       FontSize="13" VerticalAlignment="Center"
                       IsVisible="{Binding !HasSession}" />

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center"
                        IsVisible="{Binding HasSession}">
                <TextBlock h:ResoniteRichText.Text="{Binding SessionName}"
                           Foreground="{StaticResource BrushTextPrimary}"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           MaxWidth="300" TextTrimming="CharacterEllipsis" />
                <Border Background="{StaticResource BrushBgDark}" CornerRadius="4" Padding="6,2">
                    <TextBlock Text="{Binding AccessLevel}"
                               Foreground="{StaticResource BrushTextPrimary}" FontSize="11" />
                </Border>
                <Border Background="{StaticResource BrushBgDark}" CornerRadius="4" Padding="6,2">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="👥" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding UserCountText}"
                                   Foreground="{StaticResource BrushTextPrimary}" FontSize="11" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource BrushAccent}" CornerRadius="4" Padding="6,2"
                        IsVisible="{Binding IsHost}">
                    <TextBlock Text="HOST" Foreground="White" FontSize="10" FontWeight="SemiBold" />
                </Border>
            </StackPanel>

            <!-- Right: action buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                        VerticalAlignment="Center"
                        IsVisible="{Binding HasSession}">
                <Button Content="⚙" Command="{Binding OpenSettingsCommand}"
                        IsVisible="{Binding IsHost}"
                        Background="Transparent" Foreground="{StaticResource BrushTextMuted}"
                        Padding="8,4" CornerRadius="4"
                        ToolTip.Tip="セッション設定" />
                <Button Content="Leave" Command="{Binding LeaveCommand}"
                        Background="{StaticResource BrushRed}" Foreground="White"
                        Padding="10,4" CornerRadius="4" FontSize="12" />
            </StackPanel>

        </Grid>
    </Border>
</UserControl>
