<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AudioClient.GUI.ViewModels"
             xmlns:v="clr-namespace:AudioClient.GUI.Views"
             xmlns:h="clr-namespace:AudioClient.GUI.Helpers"
             x:Class="AudioClient.GUI.Views.SessionListPanel"
             x:DataType="vm:SessionListViewModel"
             Background="{StaticResource BrushBgMid}">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" BorderBrush="{StaticResource BrushBgDark}" BorderThickness="0,0,0,1" Padding="12,10">
            <TextBlock Text="SESSIONS" Foreground="{StaticResource BrushTextMuted}"
                       FontSize="11" FontWeight="SemiBold" LetterSpacing="1" />
        </Border>

        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Sessions}" Margin="4,4,4,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SessionItemViewModel">
                        <Button Classes="SessionItem"
                                Command="{Binding $parent[ItemsControl].((vm:SessionListViewModel)DataContext).SelectSessionCommand}"
                                CommandParameter="{Binding}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="{Binding IsFocused, Converter={x:Static v:BoolToBrushConverter.Instance}, ConverterParameter='Accent:Transparent'}"
                                Padding="8,6" CornerRadius="4" Margin="0,1">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Path Grid.Column="0" Width="14" Height="14" Data="{StaticResource IconSpeaker}"
                                      Fill="{StaticResource BrushTextMuted}" Stretch="Uniform"
                                      VerticalAlignment="Center" Margin="0,0,6,0" />
                                <StackPanel Grid.Column="1" Spacing="1">
                                    <TextBlock h:ResoniteRichText.Text="{Binding Name}" Foreground="{StaticResource BrushTextPrimary}"
                                               FontSize="13" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding StateLabel}" Foreground="{StaticResource BrushTextMuted}"
                                               FontSize="11" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding UserCount}" Foreground="{StaticResource BrushTextMuted}"
                                           FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0" />
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" BorderBrush="{StaticResource BrushBgDark}" BorderThickness="0,1,0,0" Padding="4,4">
            <Button Content="+ New Session"
                    Command="{Binding OpenNewSessionCommand}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                    Background="Transparent" Foreground="{StaticResource BrushTextMuted}"
                    Padding="8,6" CornerRadius="4" FontSize="13" />
        </Border>
    </Grid>
</UserControl>
