<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AudioClient.GUI.ViewModels"
             xmlns:v="clr-namespace:AudioClient.GUI.Views"
             x:Class="AudioClient.GUI.Views.VideoListPanel"
             x:DataType="vm:VideoListViewModel"
             Background="{StaticResource BrushBgMid}"
             IsVisible="{Binding HasVideos}">

    <Border BorderBrush="{StaticResource BrushBgDark}" BorderThickness="0,0,0,1">
        <Grid RowDefinitions="Auto,Auto,*" MaxHeight="460">
            <Border Grid.Row="0" Padding="12,8" BorderBrush="{StaticResource BrushBgDark}" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="VIDEOS"
                               Foreground="{StaticResource BrushTextMuted}"
                               FontSize="11" FontWeight="SemiBold" LetterSpacing="1"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding Videos.Count}"
                               Foreground="{StaticResource BrushTextMuted}"
                               FontSize="11" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    IsVisible="{Binding HasSelectedVideo}"
                    Background="Black"
                    BorderBrush="{StaticResource BrushBgDark}"
                    BorderThickness="0,0,0,1"
                    Height="220">
                <v:VlcVideoView Source="{Binding SelectedVideo.PlaybackUrl}"
                                IsPlaybackActive="{Binding SelectedVideo.IsPlaying}"
                                Position="{Binding SelectedVideo.Position}" />
            </Border>

            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Videos}" Margin="8,6">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:VideoPlayerItemViewModel">
                            <Border Background="{StaticResource BrushBgDark}"
                                    BorderBrush="{StaticResource BrushBgHover}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8"
                                    Margin="0,0,0,6">
                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding UrlDisplay}"
                                                   Foreground="{StaticResource BrushTextMuted}"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Border Grid.Row="0" Grid.Column="1"
                                            Background="{StaticResource BrushBgLight}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            VerticalAlignment="Top"
                                            Margin="8,0,0,0">
                                        <TextBlock Text="{Binding StateText}"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   FontSize="10" />
                                    </Border>

                                    <Grid Grid.Row="1" Grid.ColumnSpan="2"
                                          ColumnDefinitions="*,Auto"
                                          ColumnSpacing="8"
                                          Margin="0,8,0,0">
                                        <Slider Grid.Column="0"
                                                Minimum="0"
                                                Maximum="{Binding SeekMaximum}"
                                                Value="{Binding Position, Mode=TwoWay}"
                                                IsEnabled="{Binding CanSeek}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PositionText}"
                                                   Foreground="{StaticResource BrushTextMuted}"
                                                   FontSize="11"
                                                   MinWidth="86"
                                                   TextAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>

                                    <Grid Grid.Row="2" Grid.ColumnSpan="2"
                                          ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*"
                                          ColumnSpacing="6"
                                          Margin="0,6,0,0">
                                        <Button Grid.Column="0" Content="Play"
                                                Command="{Binding PlayCommand}"
                                                Background="{StaticResource BrushAccent}"
                                                Foreground="White"
                                                Padding="10,4" FontSize="12" CornerRadius="4" />
                                        <Button Grid.Column="1" Content="Pause"
                                                Command="{Binding PauseCommand}"
                                                Background="{StaticResource BrushBgLight}"
                                                Foreground="{StaticResource BrushTextPrimary}"
                                                Padding="10,4" FontSize="12" CornerRadius="4" />
                                        <Button Grid.Column="2" Content="Stop"
                                                Command="{Binding StopCommand}"
                                                Background="{StaticResource BrushBgLight}"
                                                Foreground="{StaticResource BrushTextPrimary}"
                                                Padding="10,4" FontSize="12" CornerRadius="4" />
                                        <Button Grid.Column="3" Content="|&lt;"
                                                Command="{Binding SeekToStartCommand}"
                                                IsEnabled="{Binding CanSeek}"
                                                Background="{StaticResource BrushBgLight}"
                                                Foreground="{StaticResource BrushTextPrimary}"
                                                Padding="8,4" FontSize="12" CornerRadius="4"
                                                ToolTip.Tip="Seek to start" />
                                        <Button Grid.Column="4" Content="View"
                                                Command="{Binding SelectCommand}"
                                                Background="{StaticResource BrushBgLight}"
                                                Foreground="{StaticResource BrushTextPrimary}"
                                                Padding="10,4" FontSize="12" CornerRadius="4" />
                                        <CheckBox Grid.Column="5"
                                                  Content="Loop"
                                                  IsChecked="{Binding IsLooping, Mode=TwoWay}"
                                                  IsEnabled="{Binding CanSeek}"
                                                  Foreground="{StaticResource BrushTextMuted}"
                                                  FontSize="12"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Right" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
