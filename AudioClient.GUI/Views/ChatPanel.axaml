<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AudioClient.GUI.ViewModels"
             xmlns:v="clr-namespace:AudioClient.GUI.Views"
             xmlns:c="clr-namespace:AudioClient.GUI.Controls"
             x:Class="AudioClient.GUI.Views.ChatPanel"
             x:DataType="vm:ChatViewModel"
             Background="{StaticResource BrushBgMid}"
             DragDrop.AllowDrop="True">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource BrushBgDark}" BorderThickness="0,0,0,1" Padding="12,10">
            <TextBlock Text="CHAT" Foreground="{StaticResource BrushTextMuted}"
                       FontSize="11" FontWeight="SemiBold" LetterSpacing="1" />
        </Border>

        <!-- Message list + placeholder -->
        <Grid Grid.Row="1">
            <ScrollViewer Name="MessagesScrollViewer">
                <ItemsControl ItemsSource="{Binding Posts}" Margin="8,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ChatPostItemViewModel">
                            <Grid ColumnDefinitions="Auto,*" Margin="0,4">

                                <!-- Avatar -->
                                <Grid Grid.Column="0" Width="32" Height="32"
                                      Margin="0,0,8,0" VerticalAlignment="Top">
                                    <Border CornerRadius="16" Background="{StaticResource BrushBgDark}">
                                        <TextBlock Text="{Binding IconLetter}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrushTextMuted}" />
                                    </Border>
                                    <Border CornerRadius="16" ClipToBounds="True"
                                            IsVisible="{Binding IconBitmap, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <Image Source="{Binding IconBitmap}" Stretch="UniformToFill" />
                                    </Border>
                                </Grid>

                                <!-- Content -->
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <!-- Username + time -->
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding Username}"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Text="{Binding TimeText}"
                                                   Foreground="{StaticResource BrushTextMuted}"
                                                   FontSize="11" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <!-- Text content -->
                                    <TextBlock Text="{Binding TextContent}"
                                               Foreground="{StaticResource BrushTextPrimary}"
                                               FontSize="13" TextWrapping="Wrap"
                                               IsVisible="{Binding HasTextContent}" />
                                    <!-- Images -->
                                    <ItemsControl ItemsSource="{Binding Contents}"
                                                  IsVisible="{Binding HasImageContent}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ChatContentItemViewModel">
                                                <Border Background="{StaticResource BrushBgDark}" CornerRadius="6"
                                                        ClipToBounds="True" Margin="0,4,0,0"
                                                        HorizontalAlignment="Left"
                                                        IsVisible="{Binding IsImage}">
                                                    <Grid>
                                                        <TextBlock Text="[Image]" Foreground="{StaticResource BrushTextMuted}"
                                                                   FontSize="12" FontStyle="Italic" Margin="8,4"
                                                                   IsVisible="{Binding ImageBitmap, Converter={x:Static ObjectConverters.IsNull}}" />
                                                        <Image Source="{Binding ImageBitmap}"
                                                               MaxWidth="320" MaxHeight="240"
                                                               Stretch="Uniform"
                                                               IsVisible="{Binding ImageBitmap, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Placeholder when chat is not available -->
            <TextBlock IsVisible="{Binding !IsChatAvailable}"
                       Text="対応セッションに移動するとチャットが利用できます"
                       Foreground="{StaticResource BrushTextMuted}"
                       FontSize="12" TextAlignment="Center" TextWrapping="Wrap"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       MaxWidth="200" Margin="16" />
        </Grid>

        <!-- Input area -->
        <Border Grid.Row="2" BorderBrush="{StaticResource BrushBgDark}" BorderThickness="0,1,0,0"
                Padding="8,8" IsEnabled="{Binding IsChatAvailable}">
            <StackPanel Spacing="6">

                <!-- Image preview (visible when a file is attached) -->
                <Border IsVisible="{Binding AttachedFilePath, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Background="{StaticResource BrushBgDark}" CornerRadius="6"
                        Padding="4" HorizontalAlignment="Left" ClipToBounds="True">
                    <Grid>
                        <Image Source="{Binding AttachedPreview}"
                               MaxWidth="160" MaxHeight="120" Stretch="Uniform" />
                        <Button Content="✕"
                                Command="{Binding ClearAttachmentCommand}"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="#99000000" Foreground="White"
                                FontSize="10" Padding="3,1" CornerRadius="3"
                                Margin="2" />
                    </Grid>
                </Border>

                <!-- Text input row -->
                <Grid ColumnDefinitions="*,Auto">
                    <c:ImeAwareTextBox Grid.Column="0"
                             Text="{Binding InputText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             Watermark="メッセージを入力..."
                             Background="{StaticResource BrushBgDark}"
                             Foreground="{StaticResource BrushTextPrimary}"
                             BorderThickness="0" CornerRadius="4" Padding="8,6"
                             FontSize="13"
                             Name="InputTextBox"
                             KeyDown="InputTextBox_KeyDown" />
                    <Button Grid.Column="1"
                            Content="送信"
                            Command="{Binding SendCommand}"
                            Background="{StaticResource BrushAccent}" Foreground="White"
                            Margin="6,0,0,0" Padding="10,6" CornerRadius="4"
                            FontSize="13" />
                </Grid>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>
